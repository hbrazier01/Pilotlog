{
  "name": "@repo/airlog-contract",
  "version": "0.1.0",
  "license": "GPL-3.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc --project tsconfig.build.json && cp -Rf ./src/managed ./dist/managed && cp ./src/airlog.compact ./dist",
    "compact": "export COMPACT_PATH=$COMPACT_PATH:./node_modules:../../node_modules:../../../node_modules && node ../../compact/src/run-compactc.cjs compile src/airlog.compact src/managed/airlog",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "eslint": "^9.28.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "midnight-contracts": "git+https://riusricardo@github.com/riusricardo/midnight-contracts"
  }
}
